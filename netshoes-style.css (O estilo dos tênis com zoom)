* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Arial', sans-serif; }

:root {
    --purple: #5d2d91;
    --bg: #f4f4f4;
}

body { background: var(--bg); color: #333; }

/* Navbar */
.navbar {
    display: flex; justify-content: space-between; padding: 15px 40px;
    background: #fff; border-bottom: 3px solid var(--purple);
    position: sticky; top: 0; z-index: 100; align-items: center;
}
.logo { color: var(--purple); font-size: 24px; font-weight: 900; font-style: italic; }
.menu span { margin-left: 20px; font-weight: 700; font-size: 13px; cursor: pointer; }

/* Vitrine */
.content { padding: 40px; max-width: 1200px; margin: 0 auto; }
.section-header h1 { font-size: 28px; font-weight: 900; margin-bottom: 30px; border-left: 5px solid var(--purple); padding-left: 15px; }

/* Grid */
.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
}

/* Card e Efeito de Movimento */
.card {
    background: #fff; padding: 20px; border-radius: 10px;
    text-align: center; border: 1px solid #eee;
    transition: box-shadow 0.3s ease;
    overflow: hidden; /* Importante para o zoom não sair do card */
}

.card:hover {
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
}

.img-container {
    width: 100%; height: 220px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 15px;
}

/* EFEITO ZOOM E MOVIMENTO */
.img-container img {
    max-width: 100%;
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* Movimento suave com "salto" */
}

.card:hover .img-container img {
    transform: scale(1.15) rotate(-8deg) translateY(-10px); 
    /* Zoom de 15%, gira 8 graus e sobe 10 pixels */
}

.card h3 { font-size: 18px; margin-bottom: 5px; }
.card p { font-size: 14px; color: #777; margin-bottom: 10px; }
.price { color: var(--purple); font-weight: 900; font-size: 20px; }
